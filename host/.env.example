# ClaudeTV collector config. Copy to .env (or just edit live in the master terminal).
# The Claude OAuth token is read from CLAUDE_CREDENTIALS — it is NOT stored here.
CLAUDETV_CITY=Melbourne
CLAUDETV_LAT=-37.8136
CLAUDETV_LON=144.9631
CLAUDETV_TZ=Australia/Melbourne
CLAUDETV_USAGE_EVERY=150
CLAUDETV_WEATHER_EVERY=900
CLAUDETV_PORT=8088
CLAUDE_CREDENTIALS=~/.claude/.credentials.json

# --- Reset notifications (easiest to set from the master terminal's Notifications card) ---
# Ping you when a Claude usage window rolls over to a fresh quota.
CLAUDETV_NOTIFY_SESSION_RESET=false      # 5-hour session window
CLAUDETV_NOTIFY_WEEK_RESET=false         # 7-day week window (the Fable % rides in this message)
# Discord / Slack: paste an incoming-webhook URL to enable that channel.
CLAUDETV_NOTIFY_DISCORD_WEBHOOK=
CLAUDETV_NOTIFY_SLACK_WEBHOOK=
# Email over SMTP:
CLAUDETV_NOTIFY_EMAIL=false
CLAUDETV_SMTP_HOST=
CLAUDETV_SMTP_PORT=587
CLAUDETV_SMTP_SECURITY=starttls          # starttls | ssl | none
CLAUDETV_SMTP_FROM=
CLAUDETV_SMTP_USER=
CLAUDETV_SMTP_PASS=
CLAUDETV_NOTIFY_EMAIL_TO=
